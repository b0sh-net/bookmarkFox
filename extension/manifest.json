{
  "manifest_version": 3,
  "name": "bookmarkFox",
  "version": "1.0",
  "description": "Sync your Firefox bookmarks to bookmarkFox",
  "permissions": [
    "bookmarks",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://bookmarkfox.b0sh.net/*",
    "http://localhost/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "bookmarkfox@b0sh.net",
      "update_url": "https://raw.githubusercontent.com/b0sh-net/bookmarkFox/main/updates.json"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "bookmarkFox"
  }
}
