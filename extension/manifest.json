{
  "manifest_version": 3,
  "name": "bookmarkFox",
  "version": "1.0",
  "description": "Sync your Firefox bookmarks to bookmarkFox",
  "permissions": [
    "bookmarks",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://bookmarkfox.it/*",
    "http://localhost/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "bookmarkFox"
  }
}
