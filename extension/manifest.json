{
  "manifest_version": 3,
  "name": "bookmarkFox",
  "version": "1.0",
  "description": "Sync your Firefox bookmarks to bookmarkFox",
  "permissions": [
    "bookmarks",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://bookmarkfox.b0sh.net/*",
    "http://localhost/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "bookmarkfox@b0sh.net",
      "update_url": "https://raw.githubusercontent.com/b0sh-net/bookmarkFox/main/updates.json",
      "data_collection_permissions": {
        "required": [
          "bookmarksInfo",
          "authenticationInfo"
        ],
        "optional": []
      }
    }
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "bookmarkFox",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png",
      "128": "icons/icon-128.png"
    }
  }
}
